rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ユーザー個別データへのアクセス
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /categories/{categoryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /sentences/{sentenceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
